# Copy this to .env and fill in your values
# Never commit .env to version control

# MongoDB Atlas URI (production) or local URI (dev)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/grievance-portal

# Strong random secret — minimum 32 characters
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_this_with_a_strong_random_secret

# Token expiry in milliseconds (default: 24h = 86400000)
JWT_EXPIRATION_MS=86400000

# Your React frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Server port (default: 5000 — matches Express port)
PORT=5000

# Upload directory
UPLOAD_DIR=uploads
